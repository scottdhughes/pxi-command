{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".."
  },
  "include": [
    "./**/*.ts",
    "./worker-configuration.d.ts",
    "../src/config/**/*.ts",
    "../src/types/**/*.ts"
  ],
  "exclude": [
    "../dist",
    "../node_modules"
  ]
}
